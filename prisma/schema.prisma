generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. ROLES Y USUARIOS
// ==========================================
enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  HOTEL
  AGENCY
  DRIVER
  CUSTOMER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  fullName      String
  role          Role      @default(CUSTOMER)
  phone         String?
  isActive      Boolean   @default(true)
  
  // Relaciones
  driverProfile Driver?
  customerProfile Customer?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// 2. CLIENTES (Usuarios Finales)
// ==========================================
model Customer {
  id            String    @id @default(uuid())
  userId        String?   @unique
  user          User?     @relation(fields: [userId], references: [id])
  
  email         String    @unique
  fullName      String
  phone         String?
  country       String?
  preferredLanguage String? @default("en")
  
  bookings      Booking[]
  
  totalSpent    Decimal   @default(0) @db.Decimal(10, 2)
  totalBookings Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// 3. FLOTA Y VEHÍCULOS
// ==========================================
model VehicleCategory {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  description   String?
  vehicles      Vehicle[]
}

model Vehicle {
  id                  String    @id @default(uuid())
  categoryId          String
  category            VehicleCategory @relation(fields: [categoryId], references: [id])
  
  name                String
  slug                String    @unique
  imageUrl            String?
  
  passengerCapacity   Int
  luggageCapacity     Int
  
  pricePerKmOneWay    Decimal   @db.Decimal(10, 2)
  pricePerKmRoundTrip Decimal   @db.Decimal(10, 2)
  pricePerHour        Decimal   @db.Decimal(10, 2)
  minimumPrice        Decimal   @db.Decimal(10, 2)
  
  airportSurcharge    Decimal   @default(0) @db.Decimal(10, 2)
  nightSurcharge      Decimal   @default(0) @db.Decimal(10, 2)
  
  isActive            Boolean   @default(true)
  sortOrder           Int       @default(0)
  
  bookings            Booking[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 4. B2B: HOTELES Y AGENCIAS
// ==========================================
model Hotel {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  token               String    @unique
  
  contactName         String?
  email               String?
  phone               String?
  
  commissionValue     Decimal   @default(0) @db.Decimal(10, 2)
  discountValue       Decimal   @default(0) @db.Decimal(10, 2)
  
  isActive            Boolean   @default(true)
  
  bookings            Booking[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Agency {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  token           String   @unique
  
  contactName     String?
  email           String?
  phone           String?
  
  commissionValue Decimal  @default(0) @db.Decimal(10, 2)
  discountValue   Decimal  @default(0) @db.Decimal(10, 2)
  
  isActive        Boolean  @default(true)
  
  bookings        Booking[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// 5. CONDUCTORES
// ==========================================
enum DriverAssignmentStatus {
  ASIGNADO
  EN_CAMINO
  EN_PUNTO_DE_RECOGIDA
  CLIENTE_RECOGIDO
  SERVICIO_FINALIZADO
  INCIDENCIA
}

model Driver {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id])
  
  licenseNumber       String?
  status              String    @default("ACTIVE")
  
  bookings            Booking[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 6. MOTOR DE PRECIOS Y REGLAS
// ==========================================
model PriceRule {
  id                  String   @id @default(uuid())
  name                String
  description         String?
  type                String   // Ej. NIGHT_SURCHARGE, WEEKEND_SURCHARGE, AIRPORT_FEE
  valueType           String   // PERCENTAGE, FIXED
  value               Decimal  @db.Decimal(10, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DiscountCode {
  id                  String   @id @default(uuid())
  code                String   @unique
  description         String?
  valueType           String   // PERCENTAGE, FIXED
  value               Decimal  @db.Decimal(10, 2)
  maxUses             Int?
  usedCount           Int      @default(0)
  validFrom           DateTime?
  validUntil          DateTime?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ==========================================
// 7. MOTOR DE RESERVAS
// ==========================================
enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  POR_CONFIRMAR
  CONFIRMADA
  ASIGNADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  NO_SHOW
  REEMBOLSADA
  FALLIDA
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum SourceType {
  WEB_DIRECT
  HOTEL_QR
  AGENCY_LINK
  MANUAL_ADMIN
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
  HOURLY
}

model Booking {
  id                  String    @id @default(uuid())
  publicCode          String    @unique
  
  customerId          String
  customer            Customer  @relation(fields: [customerId], references: [id])
  
  vehicleId           String
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id])
  
  originAddress       String
  destinationAddress  String
  distanceKm          Decimal   @db.Decimal(10, 2)
  durationMinutes     Int
  
  serviceDate         DateTime
  serviceTime         String
  tripType            TripType  @default(ONE_WAY)
  
  passengers          Int
  luggage             Int
  flightNumber        String?
  
  basePrice           Decimal   @db.Decimal(10, 2)
  discountAmount      Decimal   @default(0) @db.Decimal(10, 2)
  surchargeAmount     Decimal   @default(0) @db.Decimal(10, 2)
  finalPrice          Decimal   @db.Decimal(10, 2)
  currency            String    @default("EUR")
  
  sourceType          SourceType @default(WEB_DIRECT)
  hotelId             String?
  hotel               Hotel?    @relation(fields: [hotelId], references: [id])
  agencyId            String?
  agency              Agency?   @relation(fields: [agencyId], references: [id])
  
  driverId            String?
  driver              Driver?   @relation(fields: [driverId], references: [id])
  driverStatus        DriverAssignmentStatus?
  
  bookingStatus       BookingStatus @default(PENDING_PAYMENT)
  paymentStatus       PaymentStatus @default(PENDING)
  
  customerNotes       String?   @db.Text
  internalNotes       String?   @db.Text
  
  payments            Payment[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 8. PAGOS (Redsys)
// ==========================================
model Payment {
  id                  String    @id @default(uuid())
  bookingId           String
  booking             Booking   @relation(fields: [bookingId], references: [id])
  
  provider            String    @default("REDSYS")
  providerOrderId     String?
  
  amount              Decimal   @db.Decimal(10, 2)
  currency            String    @default("EUR")
  
  status              PaymentStatus @default(PENDING)
  responseCode        String?
  signatureValid      Boolean   @default(false)
  
  rawRequest          String?   @db.Text
  rawResponse         String?   @db.Text
  
  paidAt              DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 9. AUDITORÍA Y NOTIFICACIONES
// ==========================================
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  // UUID del administrador o sistema
  entityType  String   // Ej. Booking, Vehicle
  entityId    String   // ID del registro modificado
  action      String   // CREATE, UPDATE, DELETE
  oldValue    String?  @db.Text // JSON stringificado
  newValue    String?  @db.Text // JSON stringificado
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model NotificationTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  subject     String
  body        String   @db.Text
  type        String   // EMAIL, WHATSAPP
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationLog {
  id          String   @id @default(uuid())
  bookingId   String?
  recipient   String   // Email o Teléfono
  type        String   // EMAIL, WHATSAPP
  status      String   // SENT, FAILED
  errorReason String?  @db.Text
  sentAt      DateTime @default(now())
}

// ==========================================
// 10. CONFIGURACIÓN DEL SISTEMA
// ==========================================
model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}
