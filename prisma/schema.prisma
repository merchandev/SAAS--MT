generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ROLES Y USUARIOS (Auth y Staff)
// ==========================================
enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  HOTEL
  AGENCY
  DRIVER
  CUSTOMER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  fullName      String
  role          Role      @default(CUSTOMER)
  phone         String?
  isActive      Boolean   @default(true)
  
  // Relaciones
  driverProfile Driver?
  customerProfile Customer?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// 2. CLIENTES (Usuarios Finales)
// ==========================================
model Customer {
  id            String    @id @default(uuid())
  userId        String?   @unique
  user          User?     @relation(fields: [userId], references: [id])
  
  email         String    @unique // Puede ser diferente al User de login
  fullName      String
  phone         String?
  country       String?
  preferredLanguage String? @default("en")
  
  // Relaciones
  bookings      Booking[]
  
  totalSpent    Float     @default(0)
  totalBookings Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// 3. FLOTA Y VEHÍCULOS
// ==========================================
model VehicleCategory {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  description   String?
  vehicles      Vehicle[]
}

model Vehicle {
  id                  String    @id @default(uuid())
  categoryId          String
  category            VehicleCategory @relation(fields: [categoryId], references: [id])
  
  name                String
  slug                String    @unique
  imageUrl            String?
  
  passengerCapacity   Int
  luggageCapacity     Int
  
  pricePerKmOneWay    Float
  pricePerKmRoundTrip Float
  pricePerHour        Float
  minimumPrice        Float
  
  airportSurcharge    Float     @default(0)
  nightSurcharge      Float     @default(0)
  
  isActive            Boolean   @default(true)
  sortOrder           Int       @default(0)
  
  bookings            Booking[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 4. B2B: HOTELES Y AGENCIAS
// ==========================================
model Hotel {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  token               String    @unique // Para generar QR
  
  contactName         String?
  email               String?
  phone               String?
  
  commissionValue     Float     @default(0)
  discountValue       Float     @default(0)
  
  isActive            Boolean   @default(true)
  
  bookings            Booking[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 5. CONDUCTORES
// ==========================================
model Driver {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id])
  
  licenseNumber       String?
  status              String    @default("ACTIVE") // ACTIVE, INACTIVE, ON_DUTY
  
  bookings            Booking[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 6. MOTOR DE RESERVAS
// ==========================================
enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  POR_CONFIRMAR
  CONFIRMADA
  ASIGNADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  NO_SHOW
  REEMBOLSADA
  FALLIDA
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

model Booking {
  id                  String    @id @default(uuid())
  publicCode          String    @unique // Ej. MT-2026-A8F2
  
  // Clientes
  customerId          String
  customer            Customer  @relation(fields: [customerId], references: [id])
  
  // Vehículo
  vehicleId           String
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id])
  
  // Ruta
  originAddress       String
  destinationAddress  String
  distanceKm          Float
  durationMinutes     Int
  
  serviceDate         DateTime
  serviceTime         String
  tripType            String    @default("ONE_WAY") // ONE_WAY, ROUND_TRIP
  
  passengers          Int
  luggage             Int
  flightNumber        String?
  
  // Precios
  basePrice           Float
  discountAmount      Float     @default(0)
  surchargeAmount     Float     @default(0)
  finalPrice          Float
  currency            String    @default("EUR")
  
  // Relaciones Operativas
  hotelId             String?
  hotel               Hotel?    @relation(fields: [hotelId], references: [id])
  
  driverId            String?
  driver              Driver?   @relation(fields: [driverId], references: [id])
  
  // Estados
  bookingStatus       BookingStatus @default(PENDING_PAYMENT)
  paymentStatus       PaymentStatus @default(PENDING)
  
  // Notas
  customerNotes       String?   @db.Text
  internalNotes       String?   @db.Text
  
  // Pagos
  payments            Payment[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ==========================================
// 7. PAGOS (Redsys)
// ==========================================
model Payment {
  id                  String    @id @default(uuid())
  bookingId           String
  booking             Booking   @relation(fields: [bookingId], references: [id])
  
  provider            String    @default("REDSYS")
  providerOrderId     String?
  
  amount              Float
  currency            String    @default("EUR")
  
  status              PaymentStatus @default(PENDING)
  responseCode        String?
  signatureValid      Boolean   @default(false)
  
  rawRequest          String?   @db.Text
  rawResponse         String?   @db.Text
  
  paidAt              DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}
