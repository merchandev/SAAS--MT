generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. ROLES Y USUARIOS
// ==========================================
enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  HOTEL
  AGENCY
  DRIVER
  CUSTOMER
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  fullName     String
  role         Role    @default(CUSTOMER)
  phone          String?
  isActive       Boolean @default(true)
  sessionVersion Int     @default(0)

  // Relaciones
  driverProfile   Driver?
  customerProfile Customer?

  hotelId  String?
  hotel    Hotel?  @relation(fields: [hotelId], references: [id])
  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. CLIENTES (Usuarios Finales)
// ==========================================
model Customer {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  email             String  @unique
  fullName          String
  phone             String?
  country           String?
  preferredLanguage String? @default("en")

  bookings    Booking[]
  invoices    Invoice[]
  reviews     Review[]
  suggestions CustomerSuggestion[]
  addresses   CustomerAddress[]

  totalSpent    Decimal @default(0) @db.Decimal(10, 2)
  totalBookings Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerAddress {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  label       String
  address     String
  placeId     String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 3. FLOTA Y VEHÍCULOS
// ==========================================
model VehicleCategory {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  vehicles    Vehicle[]
}

model Vehicle {
  id         String          @id @default(uuid())
  categoryId String
  category   VehicleCategory @relation(fields: [categoryId], references: [id])

  name     String
  slug     String  @unique
  imageUrl String?

  passengerCapacity Int
  luggageCapacity   Int

  pricePerKmOneWay    Decimal @db.Decimal(10, 2)
  pricePerKmRoundTrip Decimal @db.Decimal(10, 2)
  pricePerHour        Decimal @db.Decimal(10, 2)
  minimumPrice        Decimal @db.Decimal(10, 2)

  airportSurcharge Decimal @default(0) @db.Decimal(10, 2)
  nightSurcharge   Decimal @default(0) @db.Decimal(10, 2)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  bookings     Booking[]
  availability VehicleAvailability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 4. B2B: HOTELES Y AGENCIAS
// ==========================================
model Hotel {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  token String @unique

  contactName String?
  email       String?
  phone       String?

  address        String?
  placeId        String?
  routesSettings Json? // Stores predefined destinations and prices

  commissionValue Decimal @default(0) @db.Decimal(10, 2)
  discountValue   Decimal @default(0) @db.Decimal(10, 2)

  isActive Boolean @default(true)

  bookings Booking[]
  users    User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agency {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  token String @unique

  contactName String?
  email       String?
  phone       String?

  commissionValue Decimal @default(0) @db.Decimal(10, 2)
  discountValue   Decimal @default(0) @db.Decimal(10, 2)

  isActive Boolean @default(true)

  bookings Booking[]
  users    User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 5. CONDUCTORES
// ==========================================
enum DriverAssignmentStatus {
  ASIGNADO
  EN_CAMINO
  EN_PUNTO_DE_RECOGIDA
  CLIENTE_RECOGIDO
  SERVICIO_FINALIZADO
  INCIDENCIA
}

model Driver {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  licenseNumber String?
  status        String  @default("ACTIVE")

  // Tracking en tiempo real
  currentLat         Float?
  currentLng         Float?
  lastLocationUpdate DateTime?

  bookings     Booking[]
  availability DriverAvailability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DriverAvailability {
  id       String @id @default(uuid())
  driverId String
  driver   Driver @relation(fields: [driverId], references: [id])

  startsAt DateTime
  endsAt   DateTime
  status   String
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId, startsAt, endsAt])
}

model VehicleAvailability {
  id        String  @id @default(uuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  startsAt DateTime
  endsAt   DateTime
  status   String
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId, startsAt, endsAt])
}

// ==========================================
// 6. MOTOR DE PRECIOS Y REGLAS
// ==========================================
model PriceRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String // Ejemplo: NIGHT_SURCHARGE, WEEKEND_SURCHARGE, AIRPORT_FEE
  valueType   String // PERCENTAGE, FIXED
  value       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DiscountCode {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  valueType   String // PERCENTAGE, FIXED
  value       Decimal   @db.Decimal(10, 2)
  maxUses     Int?
  usedCount   Int       @default(0)
  validFrom   DateTime?
  validUntil  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum ZoneType {
  AIRPORT
  PORT
  TRAIN_STATION
  CITY
  HOTEL_AREA
}

model Zone {
  id        String   @id @default(uuid())
  name      String
  type      ZoneType
  placeId   String?  @unique
  keywords  String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 7. MOTOR DE RESERVAS
// ==========================================
enum BookingStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  POR_CONFIRMAR
  CONFIRMADA
  ASIGNADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  NO_SHOW
  REEMBOLSADA
  FALLIDA
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum SourceType {
  WEB_DIRECT
  HOTEL_QR
  AGENCY_LINK
  MANUAL_ADMIN
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

model Booking {
  id         String @id @default(uuid())
  publicCode String @unique

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  originAddress      String
  originPlaceId      String?
  destinationAddress String
  destinationPlaceId String?
  distanceKm         Decimal @db.Decimal(10, 2)
  durationMinutes    Int

  serviceDate DateTime
  serviceTime String
  tripType    TripType @default(ONE_WAY)

  passengers   Int
  luggage      Int
  flightNumber String?

  basePrice       Decimal @db.Decimal(10, 2)
  discountAmount  Decimal @default(0) @db.Decimal(10, 2)
  surchargeAmount Decimal @default(0) @db.Decimal(10, 2)
  finalPrice      Decimal @db.Decimal(10, 2)
  currency        String  @default("EUR")
  priceBreakdown  Json?

  sourceType SourceType @default(WEB_DIRECT)
  hotelId    String?
  hotel      Hotel?     @relation(fields: [hotelId], references: [id])
  agencyId   String?
  agency     Agency?    @relation(fields: [agencyId], references: [id])

  driverId     String?
  driver       Driver?                 @relation(fields: [driverId], references: [id])
  driverStatus DriverAssignmentStatus?

  bookingStatus BookingStatus @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus @default(PENDING)

  customerNotes String?   @db.Text
  internalNotes String?   @db.Text
  deletedAt     DateTime?
  deletedBy     String?
  deletedReason String?   @db.Text

  payments      Payment[]
  statusHistory BookingStatusHistory[]
  invoice       Invoice?
  review        Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
  @@index([bookingStatus])
  @@index([serviceDate])
  @@index([driverId])
  @@index([hotelId])
  @@index([agencyId])
  @@index([customerId])
  @@index([createdAt])
  @@index([bookingStatus, serviceDate])
  @@index([driverId, serviceDate])
}

// ==========================================
// 8. PAGOS (Redsys)
// ==========================================
model Payment {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  provider        String  @default("REDSYS")
  providerOrderId String? @unique

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("EUR")

  status         PaymentStatus @default(PENDING)
  responseCode   String?
  signatureValid Boolean       @default(false)

  rawRequest  String? @db.Text
  rawResponse String? @db.Text

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 9. AUDITORÍA Y NOTIFICACIONES
// ==========================================
model AuditLog {
  id         String   @id @default(uuid())
  userId     String? // UUID del administrador o sistema
  entityType String // Ejemplo: Booking, Vehicle
  entityId   String // ID del registro modificado
  action     String // CREATE, UPDATE, DELETE
  oldValue   String?  @db.Text // JSON stringificado
  newValue   String?  @db.Text // JSON stringificado
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String   @db.Text
  type      String // EMAIL, WHATSAPP
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id          String   @id @default(uuid())
  bookingId   String?
  recipient   String // Email o Teléfono
  type        String // EMAIL, WHATSAPP
  status      String // SENT, FAILED
  errorReason String?  @db.Text
  sentAt      DateTime @default(now())
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model MapsDistanceCache {
  key             String   @id
  origin          String
  destination     String
  distanceKm      Float
  durationMinutes Int
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expiresAt])
}

// ==========================================
// 10. CONFIGURACIÓN DEL SISTEMA
// ==========================================
model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 11. MODELOS ADICIONALES (Facturación, Reseñas, Logs)
// ==========================================

model BookingStatusHistory {
  id        String        @id @default(uuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id])
  oldStatus BookingStatus
  newStatus BookingStatus
  changedBy String? // userId del admin/sistema
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
}

model RedsysLog {
  id               String   @id @default(uuid())
  bookingId        String?
  orderId          String?
  transactionType  String // NOTIFICATION, SUCCESS, ERROR
  rawPayload       String   @db.Text
  responseCode     String?
  isSignatureValid Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id])
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])

  subtotal    Decimal @db.Decimal(10, 2)
  taxAmount   Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)
  currency    String  @default("EUR")

  issuedAt DateTime @default(now())
  pdfUrl   String?
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  rating      Int // 1-5
  comment     String? @db.Text
  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
}

model CustomerSuggestion {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  subject String
  message String @db.Text
  status  String @default("NEW")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model RoutePage {
  id              String  @id @default(uuid())
  slug            String  @unique // Ejemplo: traslados-aeropuerto-mallorca-alcudia
  originName      String
  destinationName String
  h1Title         String
  metaDescription String? @db.Text
  contentHtml     String? @db.Text

  seoTitle        String?
  seoKeywords     String?
  seoImage        String?

  basePriceCache Decimal? @db.Decimal(10, 2) // Cacheo para pintar "Desde X €" rápido

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id              String  @id @default(uuid())
  slug            String  @unique
  title           String
  excerpt         String? @db.Text
  contentHtml     String? @db.Text
  
  metaTitle       String?
  metaDescription String? @db.Text
  seoKeywords     String?
  imageUrl        String?

  isActive    Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  status    String   @default("NEW") // NEW, READ, REPLIED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
