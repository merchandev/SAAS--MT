# ==========================================
# MeTransfers SaaS — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ==========================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=metransfers
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=metransfers_saas
DATABASE_URL="postgresql://metransfers:cambia_esta_password@localhost:5432/metransfers_saas?schema=public"

# --- pgAdmin (opcional, solo Docker) ---
PGADMIN_DEFAULT_EMAIL=admin@metransfers.com
PGADMIN_DEFAULT_PASSWORD=cambia_esta_password

# --- Autenticación JWT ---
# Genera un valor seguro con: openssl rand -base64 64
# OBLIGATORIO: El servidor crasheará si no existe en producción.
JWT_SECRET=cambia_este_secreto_muy_largo_y_aleatorio

# --- Usuario admin inicial para prisma/seed.ts ---
ADMIN_EMAIL=admin@metransfers.com
ADMIN_PASSWORD=cambia_esta_password_larga_123

# --- Aplicación ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_PORT=3000
# Opcional. Por defecto se activa solo si NEXT_PUBLIC_APP_URL usa https:// en producción.
AUTH_COOKIE_SECURE=

# --- Google Maps (obligatorio para cotizaciones/reservas reales) ---
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- OpenAI Image API (solo servidor) ---
# Nunca publiques esta clave como NEXT_PUBLIC_*. Se usa solo desde rutas server-side.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# --- Rate limit ---
# En producción use database para compartir límites entre contenedores.
RATE_LIMIT_BACKEND=database

# --- Redsys (pasarela de pago España) ---
# Entorno de test: https://sis-t.redsys.es:25443/sis/realizarPago
# Entorno real:    https://sis.redsys.es/sis/realizarPago
REDSYS_URL=https://sis.redsys.es/sis/realizarPago
REDSYS_MERCHANT_CODE=
REDSYS_TERMINAL=1
# OBLIGATORIO: El servidor crasheará en producción si falta esta clave.
REDSYS_SECRET_KEY=
